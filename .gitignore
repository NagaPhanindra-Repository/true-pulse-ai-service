# .gitignore updates for sensitive files
# Add this to your .gitignore if not already there

# Environment Variables
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Build
target/
build/
dist/
*.class
*.jar
*.war

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
Thumbs.db
.DS_Store

# Security
secrets/
keys/
*.pem
*.key

